MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/timelyx
JWT_SECRET=replace-with-a-strong-secret
FRONTEND_BASE_URL=http://localhost:5173
RESET_PASSWORD_EXPIRES_MINUTES=15

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/users/oauth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/users/oauth/microsoft/callback

# Email Configuration (Gmail)
# Use your Gmail address and an App-specific password
# See: https://support.google.com/accounts/answer/185833
GMAIL_USER=supporttimelyx@gmail.com
GMAIL_PASSWORD=your-app-specific-password-here
CONTACT_RECEIVER_EMAIL=supporttimelyx@gmail.com

# Optional aliases for compatibility:
# GMAIL_PASS=your-app-specific-password-here
# EMAIL_USER=supporttimelyx@gmail.com
# EMAIL_PASSWORD=your-app-specific-password-here

# Optional custom SMTP (if not using Gmail service):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# MAIL_SEND_TIMEOUT_MS=45000
# SMTP_FROM=supporttimelyx@gmail.com
