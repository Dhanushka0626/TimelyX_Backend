MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/timelyx
JWT_SECRET=replace-with-a-strong-secret
FRONTEND_BASE_URL=https://timely-x-frontend.vercel.app
# Local example: FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=https://timely-x-frontend.vercel.app,http://localhost:5173,http://localhost:5174
# Add other origins as needed (comma separated)
# Trailing slash is allowed (e.g. https://timely-x-frontend.vercel.app/)
RESET_PASSWORD_EXPIRES_MINUTES=15

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://timelyx-backend-1.onrender.com/users/oauth/google/callback
# Local example: GOOGLE_REDIRECT_URI=http://localhost:3000/users/oauth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://timelyx-backend-1.onrender.com/users/oauth/microsoft/callback
# Local example: MICROSOFT_REDIRECT_URI=http://localhost:3000/users/oauth/microsoft/callback

# Email Configuration (Gmail)
# Use your Gmail address and an App-specific password
# See: https://support.google.com/accounts/answer/185833
GMAIL_USER=supporttimelyx@gmail.com
GMAIL_PASSWORD=your-app-specific-password-here
CONTACT_RECEIVER_EMAIL=supporttimelyx@gmail.com

# Optional aliases for compatibility:
# GMAIL_PASS=your-app-specific-password-here
# EMAIL_USER=supporttimelyx@gmail.com
# EMAIL_PASSWORD=your-app-specific-password-here

# Optional custom SMTP (if not using Gmail service):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# SMTP_CONNECTION_TIMEOUT=10000
# SMTP_GREETING_TIMEOUT=10000
# SMTP_SOCKET_TIMEOUT=20000
# SMTP_DNS_TIMEOUT=10000
# MAIL_SEND_TIMEOUT_MS=20000
